<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Error digest{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        body { background: #f6f7f9; }
        .ed-wrap { max-width: 1200px; margin: 24px auto; padding: 0 16px; }
        .ed-header { display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid #dee2e6; padding-bottom: 12px; margin-bottom: 20px; }
        .ed-header h1 { font-size: 22px; margin: 0; }
        .ed-header small { color: #666; font-weight: normal; font-size: 12px; margin-left: 8px; }
        .badge-level { font-size: 11px; font-weight: 600; letter-spacing: .03em; padding: 3px 8px; }
        .badge-level-emergency, .badge-level-alert, .badge-level-critical { background: #7a1b1b; color: #fff; }
        .badge-level-error { background: #c0392b; color: #fff; }
        .badge-level-warning { background: #e59e1a; color: #fff; }
        .badge-level-notice, .badge-level-info { background: #3498db; color: #fff; }
        .badge-level-debug { background: #888; color: #fff; }
        .badge-status-open { background: #e55353; color: #fff; }
        .badge-status-resolved { background: #2eb85c; color: #fff; }
        .badge-status-muted { background: #8c8c8c; color: #fff; }
        .fp-code { font-family: "SF Mono", Consolas, monospace; font-size: 11px; color: #555; }
        .stack { background: #1e1e1e; color: #e6e6e6; padding: 12px; border-radius: 4px; font-family: "SF Mono", Consolas, monospace; font-size: 11px; white-space: pre-wrap; overflow-x: auto; }
        .ctx { background: #f4f6f9; border: 1px solid #e3e5ea; border-radius: 4px; padding: 10px; font-family: "SF Mono", Consolas, monospace; font-size: 11px; white-space: pre-wrap; }
        table.ed-fp th { font-size: 11px; text-transform: uppercase; color: #666; letter-spacing: .04em; }
    </style>
</head>
<body>
<div class="ed-wrap">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>
</body>
</html>
