<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Error digest — {{ payload.environment }}</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; color: #1a1a1a; max-width: 760px; margin: 0 auto; padding: 24px; background: #f6f7f9; }
        h1 { font-size: 18px; margin: 0 0 4px; }
        h2 { font-size: 14px; text-transform: uppercase; letter-spacing: .05em; color: #555; margin: 32px 0 8px; border-bottom: 1px solid #e3e5ea; padding-bottom: 6px; }
        .meta { color: #666; font-size: 13px; margin-bottom: 20px; }
        .levels { margin: 16px 0; padding: 12px 16px; background: #fff; border-radius: 6px; border: 1px solid #e3e5ea; }
        .lvl { display: inline-block; padding: 3px 10px; border-radius: 10px; margin-right: 8px; font-size: 12px; font-weight: 600; }
        .lvl-critical, .lvl-emergency, .lvl-alert { background: #7a1b1b; color: #fff; }
        .lvl-error { background: #c0392b; color: #fff; }
        .lvl-warning { background: #e59e1a; color: #fff; }
        .lvl-notice, .lvl-info { background: #3498db; color: #fff; }
        .lvl-debug { background: #888; color: #fff; }
        table { width: 100%; border-collapse: collapse; margin-top: 8px; background: #fff; border: 1px solid #e3e5ea; border-radius: 6px; overflow: hidden; }
        th { text-align: left; font-size: 12px; text-transform: uppercase; color: #666; background: #f0f2f5; padding: 10px 12px; letter-spacing: .04em; }
        td { padding: 10px 12px; border-top: 1px solid #e3e5ea; vertical-align: top; font-size: 13px; }
        tr:first-child td { border-top: none; }
        td.fp { font-family: "SF Mono", Consolas, monospace; font-size: 11px; color: #666; }
        td.msg { color: #1a1a1a; }
        td.msg small { color: #888; display: block; font-size: 11px; margin-top: 2px; }
        .empty { color: #888; font-style: italic; font-size: 13px; padding: 8px 0; }
        .footer { margin-top: 32px; font-size: 11px; color: #999; border-top: 1px solid #e3e5ea; padding-top: 16px; }
    </style>
</head>
<body>

<h1>Error digest — {{ payload.environment }}</h1>
<div class="meta">
    Window {{ payload.windowStart|date('Y-m-d H:i') }} → {{ payload.windowEnd|date('Y-m-d H:i') }}
    · generated {{ payload.generatedAt|date('Y-m-d H:i T') }}
</div>

{% if payload.levelCounts is not empty %}
    <div class="levels">
        {% for level, count in payload.levelCounts %}
            <span class="lvl lvl-{{ level }}">{{ level }}: {{ count }}</span>
        {% endfor %}
    </div>
{% endif %}

{% if payload.isEmpty %}
    <p class="empty">No fingerprints to report for this window. Quiet is good.</p>
{% endif %}

{% if payload.sections.new is defined %}
    <h2>New ({{ payload.sections.new|length }})</h2>
    {% if payload.sections.new is empty %}
        <p class="empty">No new fingerprints since last digest.</p>
    {% else %}
        {{ _self.fingerprintTable(payload.sections.new, 'window') }}
    {% endif %}
{% endif %}

{% if payload.sections.spiking is defined %}
    <h2>Spiking ({{ payload.sections.spiking|length }})</h2>
    {% if payload.sections.spiking is empty %}
        <p class="empty">No spiking fingerprints.</p>
    {% else %}
        {{ _self.fingerprintTable(payload.sections.spiking, 'spike') }}
    {% endif %}
{% endif %}

{% if payload.sections.top is defined %}
    <h2>Top by volume ({{ payload.sections.top|length }})</h2>
    {% if payload.sections.top is empty %}
        <p class="empty">No fingerprints recorded activity in this window.</p>
    {% else %}
        {{ _self.fingerprintTable(payload.sections.top, 'window') }}
    {% endif %}
{% endif %}

{% if payload.sections.stale is defined %}
    <h2>Still open ({{ payload.sections.stale|length }})</h2>
    {% if payload.sections.stale is empty %}
        <p class="empty">No stale open fingerprints.</p>
    {% else %}
        {{ _self.fingerprintTable(payload.sections.stale, 'lifetime') }}
    {% endif %}
{% endif %}

<div class="footer">
    Generated by hexis/error-digest-bundle.
</div>

{% macro fingerprintTable(rows, countMode) %}
    <table>
        <tr>
            <th>Level</th>
            <th>Fingerprint</th>
            <th>Message</th>
            <th>Channel</th>
            <th>{% if countMode == 'spike' %}Window / Prior{% elseif countMode == 'lifetime' %}Lifetime{% else %}Window{% endif %}</th>
            <th>Last seen</th>
        </tr>
        {% for row in rows %}
            <tr>
                <td><span class="lvl lvl-{{ row.levelName }}">{{ row.levelName }}</span></td>
                <td class="fp">{{ row.shortFingerprint() }}</td>
                <td class="msg">
                    {{ row.message|slice(0, 160) }}{% if row.message|length > 160 %}…{% endif %}
                    {% if row.exceptionClass %}<small>{{ row.exceptionClass }}{% if row.file %} · {{ row.file }}:{{ row.line }}{% endif %}</small>{% endif %}
                </td>
                <td>{{ row.channel }}</td>
                <td>
                    {% if countMode == 'lifetime' %}
                        {{ row.occurrenceCount }}
                    {% elseif countMode == 'spike' and row.velocityMultiplier %}
                        {{ row.windowOccurrences }} ({{ row.velocityMultiplier|number_format(1) }}×)
                    {% else %}
                        {{ row.windowOccurrences }}
                    {% endif %}
                </td>
                <td>{{ row.lastSeenAt|date('m-d H:i') }}</td>
            </tr>
        {% endfor %}
    </table>
{% endmacro %}

</body>
</html>
